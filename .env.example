# PostgreSQL connection URL
# Format: postgresql+psycopg2://user:password@host:port/dbname
DB_URL=postgresql+psycopg2://user:password@localhost:5432/mydb

# LLM provider: "claude" or "openai"
LLM_PROVIDER=claude

# Anthropic API key (used when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI API key (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# OpenAI model to use
OPENAI_MODEL=gpt-4o

# Query guardrails
QUERY_TIMEOUT_SECONDS=30
QUERY_ROW_LIMIT=10000
MAX_LLM_RETRIES=3

# Schema
SCHEMA_SAMPLE_ROWS=3

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/agent.jsonl
